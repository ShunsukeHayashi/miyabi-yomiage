# Discord Bot Token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application Client ID (required for command registration)
CLIENT_ID=your_client_id_here

# VOICEVOX API URL (default: http://localhost:50021)
VOICEVOX_URL=http://localhost:50021

# Default speaker ID (default: 3 = zundamon normal)
DEFAULT_SPEAKER=3

# Default speech speed (default: 1.2)
DEFAULT_SPEED=1.2

# Max text length for TTS (default: 200)
MAX_TEXT_LENGTH=200

# Auto-join voice channel on text message (default: true)
AUTO_JOIN=true
